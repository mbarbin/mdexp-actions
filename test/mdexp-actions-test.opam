# This file is generated by dune, edit dune-project instead
opam-version: "2.0"
synopsis: "A test project to exercise the mdexp-actions repo"
maintainer: ["Mathieu Barbin <opensource@mbarbin.org>"]
authors: ["Mathieu Barbin"]
license: "MIT"
homepage: "https://github.com/mbarbin/mdexp-actions"
bug-reports: "https://github.com/mbarbin/mdexp-actions/issues"
depends: [
  "dune" {>= "3.17"}
  "ocaml" {>= "5.2"}
  "ocamlformat" {= "0.29.0"}
  "ppx_expect" {>= "v0.17" & < "v0.18"}
  "ppxlib" {>= "0.33"}
  "print-table" {>= "0.1.0"}
  "odoc" {with-doc}
]
build: [
  ["dune" "subst"] {dev}
  [
    "dune"
    "build"
    "-p"
    name
    "-j"
    jobs
    "@install"
    "@runtest" {with-test}
    "@doc" {with-doc}
  ]
]
dev-repo: "git+https://github.com/mbarbin/mdexp-actions.git"
